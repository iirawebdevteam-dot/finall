# Lovable Cloud Configuration
# Get these values from: https://lovable.dev/dashboard/settings/api-keys

# Lovable Cloud API base URL (usually fixed)
REACT_APP_LOVABLE_CLOUD_API=https://api.lovable.dev/v1

# Your Lovable Cloud Project ID
# Find in: Settings → General → Project ID
REACT_APP_LOVABLE_PROJECT_ID=your-project-id-here

# Your Lovable Cloud API Key (keep this secret!)
# Generate in: Settings → API Keys
REACT_APP_LOVABLE_API_KEY=your-api-key-here
